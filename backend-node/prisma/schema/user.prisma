model User {
  id            String          @id @default(uuid()) @db.Uuid
  username      String          @unique
  firstName     String?
  lastName      String?
  email         String?         @unique
  avatarUrl     String?
  passwordHash  String
  role          UserRole        @default(USER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  dashboards    UserDashboard[]
}