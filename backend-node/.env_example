# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# PostgreSQL connection string
DATABASE_URL="postgresql://homelab:homelab_dev_password@localhost:5432/homelab?schema=public"

JWT_SECRET=

# Deutsche Bahn API (https://developers.deutschebahn.com/db-api-marketplace/apis/start)
# Subscribe to "Timetables" and "Station Data v2" to get these credentials.
DB_CLIENT_ID=
DB_CLIENT_SECRET=

# SMTP settings for email verification and password reset.
# Leave SMTP_HOST/SMTP_PORT/SMTP_FROM empty to disable email-based flows.
# SMTP_SECURE: "true" for TLS (port 465), "false" for STARTTLS (port 587). Auto-detected when omitted.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Homelab Dashboard <your@mail-address.de>"
SMTP_DASHBOARD_NAME="Homelab Dashboard"